async function generateBoardImage({ game, username, avatarUrl, lastFlipped, lastMatch, lastMiss, phase }) {
    const diff   = DIFFICULTIES[game.difficulty];
    const cols   = game.cols;
    const rows   = Math.ceil(game.board.length / cols);
    const CELL   = 88;
    const GUTTER = 12;
    const PAD_L  = 62;
    const PAD_T  = 165;
    const W      = PAD_L + cols * (CELL + GUTTER) + 40;
    const H      = PAD_T + rows * (CELL + GUTTER) + 125;
    const canvas = createCanvas(W, H);
    const ctx    = canvas.getContext("2d");

    // Fond style "Dieu du Tonnerre Volant" (Sombre & Éclairs)
    const bg = ctx.createRadialGradient(W / 2, H / 2, 50, W / 2, H / 2, W * 0.9);
    bg.addColorStop(0, "#0e0d07"); // Centre légèrement doré chaud ambré
    bg.addColorStop(0.6, "#05060b"); // Bleu nuit très sombre
    bg.addColorStop(1, "#020204"); // Noir d'encre
    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, W, H);

    // Particules de Sceau / Éclairs Jaunes abstraits en arrière-plan
    ctx.fillStyle = "rgba(234, 179, 8, 0.04)";
    for (let i = 0; i < 45; i++) {
        ctx.fillRect(Math.random() * W, Math.random() * H, Math.random() * 3 + 1, Math.random() * 15 + 2);
    }

    // Bordure Extérieure Cyber-Néon Impériale (Jaune Ambre & Cyan Éclair)
    const borderG = ctx.createLinearGradient(0, 0, W, H);
    borderG.addColorStop(0, "#eab308");
    borderG.addColorStop(0.3, "#06b6d4");
    borderG.addColorStop(0.7, "#000000");
    borderG.addColorStop(1, "#eab308");
    ctx.strokeStyle = borderG;
    ctx.lineWidth = 3;
    roundRect(ctx, 10, 10, W - 20, H - 20, 16);
    ctx.stroke();

    // En-tête d'Écran Métallique
    const hdrG = ctx.createLinearGradient(0, 10, W, 10);
    hdrG.addColorStop(0, "rgba(234,179,8,0.18)");
    hdrG.addColorStop(0.5, "rgba(6,182,212,0.06)");
    hdrG.addColorStop(1, "rgba(234,179,8,0.18)");
    ctx.fillStyle = hdrG;
    ctx.fillRect(11, 11, W - 22, 68);

    // Écriture du Titre (Style Minato)
    ctx.font = "bold 23px 'Courier New'";
    ctx.fillStyle = "#eab308";
    ctx.fillText("⚡ MINATO MEMORY", 30, 46);
    ctx.font = "10px 'Courier New'";
    ctx.fillStyle = "rgba(6, 182, 212, 0.8)";
    ctx.fillText(`⚡ 𝖤𝗌𝗉𝖺𝖼𝖾-𝖳𝖾𝗆𝗉𝗌 : ${game.difficulty.toUpperCase()} • ${game.theme.toUpperCase()}`, 32, 64);

    // Avatar Circulaire avec liseré double Éclair
    const ax = W - 52, ay = 45;
    ctx.save();
    ctx.beginPath();
    ctx.arc(ax, ay, 26, 0, Math.PI * 2);
    ctx.clip();
    try {
        const avatar = await loadImage(avatarUrl);
        ctx.drawImage(avatar, ax - 26, ay - 26, 52, 52);
    } catch {
        ctx.fillStyle = "#1e1b4b";
        ctx.fill();
    }
    ctx.restore();
    ctx.beginPath();
    ctx.arc(ax, ay, 28, 0, Math.PI * 2);
    ctx.strokeStyle = "#eab308";
    ctx.lineWidth = 1.5;
    ctx.stroke();

    // Barre d'Énergie du Temps Restant (Time Bar)
    const elapsed = Math.floor((Date.now() - game.startTime) / 1000);
    const remaining = Math.max(0, diff.timeLimit - elapsed);
    const statsY = 94;
    const timeBarY = statsY + 34;
    const timeBarW = W - 60;
    
    ctx.fillStyle = "rgba(255,255,255,0.04)";
    roundRect(ctx, 30, timeBarY, timeBarW, 6, 3);
    ctx.fill();
    
    const pct = remaining / diff.timeLimit;
    const barColor = pct > 0.5 ? "#eab308" : pct > 0.25 ? "#f97316" : "#ef4444";
    const barG = ctx.createLinearGradient(30, 0, 30 + timeBarW * pct, 0);
    barG.addColorStop(0, barColor);
    barG.addColorStop(1, "rgba(255,255,255,0.3)");
    ctx.fillStyle = barG;
    if (pct > 0) {
        roundRect(ctx, 30, timeBarY, Math.max(timeBarW * pct, 6), 6, 3);
        ctx.fill();
    }

    // Affichage des statistiques (Blocs Cristallins)
    const timeColor = remaining <= 15 ? "#ef4444" : remaining <= 30 ? "#f97316" : "#eab308";
    const statItems = [
        { label: "𝖯𝖠𝖨𝖱𝖤𝖲",   value: `${game.matched}/${diff.pairs}` },
        { label: "𝖤𝖲𝖲𝖠𝖨𝖲",   value: `${game.attempts}` },
        { label: "𝖢𝖧𝖱𝖮𝖭𝖮",   value: `${remaining}s`, color: timeColor },
        { label: "𝖬𝖨𝖲𝖤",     value: `${game.betFormatted}$` }
    ];
    const sW = (W - 60) / statItems.length;
    for (let i = 0; i < statItems.length; i++) {
        const sx = 30 + i * sW;
        ctx.fillStyle = "rgba(255,255,255,0.025)";
        ctx.strokeStyle = "rgba(6,182,212,0.15)";
        ctx.lineWidth = 1;
        roundRect(ctx, sx + 3, statsY - 14, sW - 6, 40, 6);
        ctx.fill();
        ctx.stroke();

        ctx.font = "bold 8px 'Courier New'";
        ctx.fillStyle = "rgba(255,255,255,0.4)";
        ctx.fillText(statItems[i].label, sx + 10, statsY);
        ctx.font = `bold ${statItems[i].value.length > 9 ? "11" : "13"}px 'Courier New'`;
        ctx.fillStyle = statItems[i].color || "#ffffff";
        ctx.fillText(statItems[i].value, sx + 10, statsY + 18);
    }

    // Coordonnées (Lettres et Chiffres stylisés)
    ctx.font = "bold 12px 'Courier New'";
    ctx.fillStyle = "rgba(234,179,8,0.5)";
    for (let c = 0; c < cols; c++) {
        const lx = PAD_L + c * (CELL + GUTTER) + CELL / 2;
        ctx.textAlign = "center";
        ctx.fillText(String.fromCharCode(65 + c), lx, PAD_T - 12);
    }
    for (let r = 0; r < rows; r++) {
        const ry = PAD_T + r * (CELL + GUTTER) + CELL / 2 + 5;
        ctx.textAlign = "right";
        ctx.fillText(String(r + 1), PAD_L - 14, ry);
    }
    ctx.textAlign = "left";

    // Cartes de la Grille (Modèle Angulaire & Futuriste)
    for (let idx = 0; idx < game.board.length; idx++) {
        const r  = Math.floor(idx / cols);
        const c  = idx % cols;
        const cx = PAD_L + c * (CELL + GUTTER);
        const cy = PAD_T + r * (CELL + GUTTER);

        const isMatched  = game.revealed[idx];
        const isFlipped  = lastFlipped?.includes(idx);
        const isMatchNow = lastMatch?.includes(idx);
        const isMissNow  = lastMiss?.includes(idx);

        let strokeColor, strokeW;
        const cardG = ctx.createLinearGradient(cx, cy, cx + CELL, cy + CELL);

        if (isMatched) { // Validée
            cardG.addColorStop(0, "#062419");
            cardG.addColorStop(1, "#020c08");
            strokeColor = "#10b981";
            strokeW = 2;
        } else if (isMatchNow) { // Juste trouvée à l'instant
            cardG.addColorStop(0, "#064e3b");
            cardG.addColorStop(1, "#062419");
            strokeColor = "#34d399";
            strokeW = 2.5;
        } else if (isMissNow) { // Erreur commise
            cardG.addColorStop(0, "#450a0a");
            cardG.addColorStop(1, "#180202");
            strokeColor = "#ef4444";
            strokeW = 2;
        } else if (isFlipped) { // Unique retournée
            cardG.addColorStop(0, "#3b2e04");
            cardG.addColorStop(1, "#110e02");
            strokeColor = "#eab308";
            strokeW = 2;
        } else { // Cachée (Dos de carte style Sceau Éclair Jaune)
            cardG.addColorStop(0, "#0a0f1d");
            cardG.addColorStop(1, "#03050a");
            strokeColor = "rgba(6,182,212,0.3)";
            strokeW = 1.2;
        }

        ctx.fillStyle = cardG;
        roundRect(ctx, cx, cy, CELL, CELL, 8);
        ctx.fill();
        ctx.strokeStyle = strokeColor;
        ctx.lineWidth = strokeW;
        ctx.stroke();

        // Rendu Intérieur des cartes
        if (isMatched || isFlipped || isMatchNow || isMissNow) {
            ctx.font = "36px 'Segoe UI Emoji'";
            ctx.textAlign = "center";
            ctx.fillText(game.board[idx], cx + CELL / 2, cy + CELL / 2 + 13);
            ctx.textAlign = "left";
            
            if (isMatched) {
                ctx.font = "bold 9px 'Courier New'";
                ctx.fillStyle = "#10b981";
                ctx.textAlign = "center";
                ctx.fillText("✓", cx + CELL - 10, cy + 14);
                ctx.textAlign = "left";
            }
        } else { // Point d'interrogation / Marque Minato
            ctx.font = "bold 20px 'Courier New'";
            ctx.fillStyle = "rgba(234, 179, 8, 0.25)";
            ctx.textAlign = "center";
            ctx.fillText("⚡", cx + CELL / 2, cy + CELL / 2 + 7);
            ctx.textAlign = "left";
        }

        // Mini repère géospatial en bas de la carte (ex: A1)
        ctx.font = "7px 'Courier New'";
        ctx.fillStyle = "rgba(255,255,255,0.18)";
        ctx.textAlign = "center";
        ctx.fillText(`${String.fromCharCode(65 + c)}${r + 1}`, cx + CELL / 2, cy + CELL - 6);
        ctx.textAlign = "left";
    }

    // Zone Inférieure des Statuts
    let statusText = "", statusColor = "#eab308";
    if (phase === "start") { statusText = "⚡ 𝖱𝖾𝗍𝗈𝗎𝗋𝗇𝖾𝗓 𝟤 𝖼𝖺𝗋𝗍𝖾𝗌 — 𝖾𝗑: 𝗆𝖾𝗆𝗈𝗋𝗒 𝖠𝖨 𝖡𝟤"; statusColor = "#eab308"; }
    else if (phase === "match") { statusText = "✨ 𝖯𝖠𝖨𝖱𝖤 𝖳𝖱𝖮𝖴𝖵𝖤́𝖤 ! 𝖵𝗈𝗎𝗌 𝖾̂𝗍𝖾𝗌 𝗋𝖺𝗉𝗂𝖽𝖾 !"; statusColor = "#10b981"; }
    else if (phase === "miss") { statusText = "💥 𝖤𝖱𝖱𝖤𝖴𝖱 ! 𝖬𝖾́𝗆𝗈𝗋𝗂𝗌𝖾𝗓 𝗅𝖾𝗌 𝗌𝖼𝖾𝖺𝗎𝗑 !"; statusColor = "#ef4444"; }
