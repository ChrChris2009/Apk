async function generateResultImage({ username, avatarUrl, win, bet, earned, newBalance, attempts, timeTaken, difficulty, matched, pairs, speedBonus }) {
    const W = 680, H = 360;
    const canvas = createCanvas(W, H);
    const ctx    = canvas.getContext("2d");

    const bg = ctx.createRadialGradient(W / 2, H / 2, 30, W / 2, H / 2, W * 0.85);
    bg.addColorStop(0, win ? "#081c15" : "#220707");
    bg.addColorStop(1, "#020305");
    ctx.fillStyle = bg;
    ctx.fillRect(0, 0, W, H);

    ctx.fillStyle = "rgba(255,255,255,0.01)";
    for (let y = 0; y < H; y += 4) ctx.fillRect(0, y, W, 1);

    const bG = ctx.createLinearGradient(0, 0, W, H);
    bG.addColorStop(0, win ? "#eab308" : "#ef4444");
    bG.addColorStop(0.5, "#1e1b4b");
    bG.addColorStop(1, win ? "#10b981" : "#b91c1c");
    ctx.strokeStyle = bG;
    ctx.lineWidth = 3;
    roundRect(ctx, 12, 12, W - 24, H - 24, 14);
    ctx.stroke();

    ctx.font = "bold 23px 'Courier New'";
    ctx.fillStyle = win ? "#eab308" : "#ef4444";
    ctx.fillText(win ? "⚡ MISSION RÉUSSIE — VICTOIRE" : "💥 ÉCHEC DE LA MISSION", 32, 52);
    ctx.font = "10px 'Courier New'";
    ctx.fillStyle = "rgba(255,255,255,0.5)";
    ctx.fillText(`${difficulty.toUpperCase()} • ${matched}/${pairs} SCEAUX ALIGNÉS`, 34, 68);

    const ax = W - 55, ay = 48;
    ctx.save();
    ctx.beginPath();
    ctx.arc(ax, ay, 28, 0, Math.PI * 2);
    ctx.clip();
    try {
        const avatar = await loadImage(avatarUrl);
        ctx.drawImage(avatar, ax - 28, ay - 28, 56, 56);
    } catch { ctx.fillStyle = "#0f172a"; ctx.fill(); }
    ctx.restore();
    ctx.beginPath();
    ctx.arc(ax, ay, 29, 0, Math.PI * 2);
    ctx.strokeStyle = win ? "#eab308" : "#ef4444";
    ctx.stroke();

    ctx.font = "bold 13px 'Courier New'";
    ctx.fillStyle = "#ffffff";
    ctx.fillText(username.toUpperCase().substring(0, 22), 32, 104);
    ctx.font = "9px 'Courier New'";
    ctx.fillStyle = "rgba(6,182,212,0.7)";
    ctx.fillText("NINJA UTILISATEUR", 32, 118);

    ctx.strokeStyle = "rgba(255,255,255,0.1)";
    ctx.beginPath(); ctx.moveTo(32, 130); ctx.lineTo(W - 32, 130); ctx.stroke();

    const statsY = 155;
    const cols = [
        { label: "𝖬𝖨𝖲𝖤",         value: `${bet}$`,        color: "#ffffff" },
        { label: win ? "𝖦𝖠𝖨𝖭" : "𝖯𝖤𝖱𝖳𝖤", value: win ? `+${earned}$` : `-${bet}$`, color: win ? "#eab308" : "#ef4444" },
        { label: "𝖲𝖮𝖫𝖣𝖤",        value: `${newBalance}$`, color: "#fbbf24" },
        { label: "𝖤𝖲𝖲𝖠𝖨𝖲",       value: `${attempts}`,    color: "#06b6d4" },
        { label: "𝖳𝖤𝖬𝖯𝖲",        value: `${Math.floor(timeTaken / 60)}:${String(timeTaken % 60).padStart(2,"0")}`, color: "#f87171" }
    ];
    const cW = (W - 60) / cols.length;
    for (let i = 0; i < cols.length; i++) {
        const cx = 30 + i * cW;
        ctx.fillStyle = "rgba(255,255,255,0.03)";
        ctx.strokeStyle = "rgba(255,255,255,0.05)";
        roundRect(ctx, cx + 3, statsY - 16, cW - 6, 52, 6);
        ctx.fill(); ctx.stroke();
        ctx.font = "8px 'Courier New'";
        ctx.fillStyle = "rgba(255,255,255,0.4)";
        ctx.fillText(cols[i].label, cx + 8, statsY);
        ctx.font = `bold ${cols[i].value.length > 9 ? "10" : "12"}px 'Courier New'`;
        ctx.fillStyle = cols[i].color;
        ctx.fillText(cols[i].value, cx + 8, statsY + 22);
    }

    if (speedBonus && win) {
        ctx.fillStyle = "rgba(234,179,8,0.08)";
        roundRect(ctx, 32, statsY + 52, W - 64, 36, 6);
        ctx.fill();
        ctx.strokeStyle = "rgba(234,179,8,0.3)";
        ctx.stroke();
        ctx.font = "bold 12px 'Courier New'";
        ctx.fillStyle = "#eab308";
        ctx.textAlign = "center";
        ctx.fillText(`⚡ BONUS ÉCLAIR JAUNE — Validé rapidement !`, W / 2, statsY + 74);
        ctx.textAlign = "left";
    }

    const accY = statsY + (speedBonus && win ? 106 : 68);
    const acc = attempts > 0 ? Math.round((matched / attempts) * 100) : 0;
    ctx.fillStyle = "rgba(255,255,255,0.05)";
    roundRect(ctx, 32, accY, W - 64, 8, 4);
    ctx.fill();
    ctx.fillStyle = win ? "#eab308" : "#ef4444";
    roundRect(ctx, 32, accY, (W - 64) * (acc / 100), 8, 4);
    ctx.fill();
    ctx.font = "bold 9px 'Courier New'";
    ctx.fillStyle = "rgba(255,255,255,0.5)";
    ctx.fillText(`PRÉCISION : ${acc}%`, 32, accY - 5);

    const d = new Date();
    ctx.font = "8px 'Courier New'";
    ctx.fillStyle = "rgba(255,255,255,0.2)";
    ctx.textAlign = "center";
    ctx.fillText(`MINATO BOT • ${d.getDate()}/${d.getMonth()+1}/${d.getFullYear()}`, W / 2, H - 15);
    ctx.textAlign = "left";

    return canvas.toBuffer("image/png");
}

async function sendBoard(message, game, username, avatarUrl, lastFlipped, lastMatch, lastMiss, phase, titleBox, bodyLines) {
    const body = S(titleBox, bodyLines, username);
    try {
        const img = await generateBoardImage({ game, username, avatarUrl, lastFlipped, lastMatch, lastMiss, phase });
        const p = `./memory_board_${game.uid}_${Date.now()}.png`;
        fs.writeFileSync(p, img);
        await message.reply({ body, attachment: fs.createReadStream(p) });
        fs.unlinkSync(p);
    } catch { await message.reply(body); }
}

async function endGame(message, game, win, username, avatarUrl) {
    activeGames.delete(game.uid);
    saveGames();

    const diff      = DIFFICULTIES[game.difficulty];  
    const timeTaken = Math.floor((Date.now() - game.startTime) / 1000);  
    const speedBonus = timeTaken <= diff.bonusSpeed;  
    const mult       = speedBonus ? diff.bonusMult : diff.multiplier;  

    let earned = 0n;  
    if (win) {  
        earned = game.bet * BigInt(Math.floor(mult * 10)) / 10n;  
        await updateUserCash(game.uid, earned);  
    }  

    const newBalance = await getUserCash(game.uid);  
    const [fBet, fEarned, fNew] = await Promise.all([  
        formatNumber(game.bet),  
        formatNumber(win ? earned : game.bet),  
        formatNumber(newBalance),  
    ]);  

    const lines = [  
        `🃏 Sceaux : ${game.matched}/${diff.pairs}`,  
        `🎯 Essais : ${game.attempts}`,  
        `⏱️ Chrono : ${Math.floor(timeTaken / 60)}m ${timeTaken % 60}s`,  
        "---",  
        win ? `✨ Gain : +${fEarned}$ (x${mult})` : `📉 Perte : -${fBet}$`,  
        (speedBonus && win) ? `⚡ Bonus Éclair Jaune Activé !` : null,  
        `💳 Solde : ${fNew}$`,  
    ].filter(Boolean);  

    const titleBox = win ? "🏆 MISSION RÉUSSIE" : "💥 MISSION ÉCHOUÉE";
    await message.reply(S(titleBox, lines, username));  

    try {  
        const img = await generateResultImage({  
            username, avatarUrl, win,  
            bet: fBet, earned: fEarned, newBalance: fNew,  
            attempts: game.attempts,  
            timeTaken,  
            difficulty: game.difficulty,  
            matched: game.matched,  
            pairs: diff.pairs,  
            speedBonus: speedBonus && win,  
        });  
        const p = `./memory_result_${game.uid}_${Date.now()}.png`;  
        fs.writeFileSync(p, img);  
        await message.reply({ body: "⚡ Rapport de l'Espace-Temps :", attachment: fs.createReadStream(p) });  
        fs.unlinkSync(p);  
    } catch {}
}

