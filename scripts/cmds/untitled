if (fs.existsSync(GAME_FILE)) {
    try {
        const raw = JSON.parse(fs.readFileSync(GAME_FILE, "utf8"));
        for (const [k, v] of Object.entries(raw)) {
            v.bet = BigInt(v.bet);
            activeGames.set(k, v);
