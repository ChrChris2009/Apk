function saveGames() {
    try {
        const obj = {};
        for (const [k, v] of activeGames) {
            obj[k] = { ...v, bet: v.bet.toString() };
        }
        fs.writeFileSync(GAME_FILE, JSON.stringify(obj, null, 2));
    } catch {}
}

const DIFFICULTIES = {
    facile:   { grid: 4, pairs: 8,  timeLimit: 600, multiplier: 2,  bonusSpeed: 300, bonusMult: 3 },
